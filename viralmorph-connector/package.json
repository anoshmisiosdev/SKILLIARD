{
  "name": "viralmorph-connector",
  "version": "0.1.0",
  "description": "Local MCP connector that turns one raw context block into platform-native social posts (Instagram, LinkedIn, X) and stages/publishes them with local Playwright browser automation. Not a web app.",
  "type": "module",
  "license": "MIT",
  "bin": {
    "viralmorph-connector": "dist/index.js"
  },
  "files": [
    "dist",
    "src/skills"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "prepare": "tsc"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "playwright": "^1.61.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.6.0"
  }
}
