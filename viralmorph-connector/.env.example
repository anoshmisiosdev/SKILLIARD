# =====================================================================
# ViralMorph Connector — environment configuration (all optional)
# Copy this file to `.env` and fill in only what you need.
# If you set nothing, the server runs in deterministic MOCK mode and
# the full demo still works end to end.
# =====================================================================

# Which generator to use for `generate_social_posts` / `regenerate_platform_post`.
#   mock      -> deterministic local generator (no network, default)
#   host      -> return the optimizer skill + brief so the host AI (Claude)
#                writes the copy itself, then refine via update_platform_post
#   anthropic -> server calls the Anthropic Messages API (needs ANTHROPIC_API_KEY)
#   openai    -> server calls an OpenAI-compatible Chat Completions API (needs OPENAI_API_KEY)
LLM_PROVIDER=mock

# --- Anthropic (only used when LLM_PROVIDER=anthropic) ---
ANTHROPIC_API_KEY=
# Optional model override (defaults to a current Claude model)
ANTHROPIC_MODEL=claude-opus-4-8

# --- OpenAI / OpenAI-compatible (only used when LLM_PROVIDER=openai) ---
OPENAI_API_KEY=
# Optional model + base URL overrides (base URL lets you point at any
# OpenAI-compatible endpoint, e.g. a local model server)
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# --- Browser backend ---
# How staging/publishing actually happens:
#   claude_in_chrome -> (DEFAULT) ViralMorph returns a step-by-step plan + text and
#                       the host AI drives the user's REAL Chrome with its
#                       Claude-in-Chrome tools (real cursor + screenshots).
#   playwright       -> ViralMorph drives its own persistent Chromium (self-contained).
BROWSER_BACKEND=claude_in_chrome

# --- Playwright settings (only used when BROWSER_BACKEND=playwright) ---
# Path to the persistent Chromium profile. Your login session lives here.
BROWSER_PROFILE_DIR=./browser_profiles/default
# Set to "true" to run headless (NOT recommended — you need to see + log in).
BROWSER_HEADLESS=false
# How long (ms) staging waits for you to finish manual login before giving up.
LOGIN_WAIT_MS=120000
